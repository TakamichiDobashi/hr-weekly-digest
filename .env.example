# このファイルは参考用です。実際の値はGitHub Secretsに設定してください。

# Anthropic APIキー（console.anthropic.com で発行）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Notion インテグレーショントークン（notion.so/my-integrations で発行）
NOTION_API_KEY=secret_xxxxxxxxxxxx

# 投稿先NotionページのID（ページURLの末尾32文字）
# 例: https://www.notion.so/ページ名-【ここの32文字】
NOTION_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
